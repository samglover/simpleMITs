{
  "name": "sass-minimal",
  "version": "1.1.5",
  "description": "A simple MITs web app",
  "type": "module",
  "main": "index.js",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "sass": "^1.70.0"
  },
  "scripts": {
    "dev": "sass --watch --update --style=expanded assets/scss:assets/css",
    "build": "sass --no-source-map --style=compressed assets/scss:assets/css",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "eslint assets/js",
    "lint:fix": "eslint assets/js --fix"
  },
  "author": "Sam Glover",
  "license": "UNLICENSED"
}
